// Prisma schema file for NetFusion platform database foundation
// Phase A5.1.2 — Core Database Models

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────────────────────────────────────
// ENUMERATIONS
// ─────────────────────────────────────────────────────────────────────────────

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
  PENDING_VERIFICATION
  DELETED
}

enum SessionStatus {
  ACTIVE
  EXPIRED
  REVOKED
  LOGGED_OUT
}

enum ProjectStatus {
  ACTIVE
  ARCHIVED
  CLOSED
  DRAFT
}

enum InvestigationStatus {
  OPEN
  IN_PROGRESS
  PENDING_REVIEW
  RESOLVED
  CLOSED
  ARCHIVED
}

enum AuditAction {
  CREATE
  READ
  UPDATE
  DELETE
  LOGIN
  LOGOUT
  EXPORT
  IMPORT
  ASSIGN
  ESCALATE
  ARCHIVE
  RESTORE
}

// ─────────────────────────────────────────────────────────────────────────────
// FOUNDATION MODEL — retained from Phase A5.1.1
// ─────────────────────────────────────────────────────────────────────────────

model SystemHealth {
  id        String    @id @default(uuid()) @db.Uuid
  status    String    @default("OK")
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@map("system_health")
}

// ─────────────────────────────────────────────────────────────────────────────
// PERMISSION
// ─────────────────────────────────────────────────────────────────────────────

/// Atomic capability token.  Format: "<resource>.<action>" e.g. "asset.read".
/// Names are globally unique and immutable once assigned.
model Permission {
  id          String   @id @default(uuid()) @db.Uuid
  name        String   @unique                  // e.g. "asset.read"
  displayName String                            // human label
  description String?
  resource    String                            // e.g. "asset"
  action      String                            // e.g. "read"
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  deletedAt   DateTime?

  rolePermissions RolePermission[]

  @@index([resource])
  @@index([action])
  @@index([createdAt])
  @@map("permissions")
}

// ─────────────────────────────────────────────────────────────────────────────
// ROLE
// ─────────────────────────────────────────────────────────────────────────────

/// Named collection of permissions.  Names are unique.
model Role {
  id          String   @id @default(uuid()) @db.Uuid
  name        String   @unique               // e.g. "admin"
  displayName String
  description String?
  isSystem    Boolean  @default(false)       // true → cannot be deleted
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  deletedAt   DateTime?

  userRoles       UserRole[]
  rolePermissions RolePermission[]

  @@index([createdAt])
  @@map("roles")
}

// ─────────────────────────────────────────────────────────────────────────────
// ROLE-PERMISSION JUNCTION
// ─────────────────────────────────────────────────────────────────────────────

model RolePermission {
  id           String     @id @default(uuid()) @db.Uuid
  roleId       String     @db.Uuid
  permissionId String     @db.Uuid
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  deletedAt    DateTime?

  role       Role       @relation(fields: [roleId],       references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
  @@index([permissionId])
  @@map("role_permissions")
}

// ─────────────────────────────────────────────────────────────────────────────
// USER
// ─────────────────────────────────────────────────────────────────────────────

/// Platform user account.  Soft-deleted via deletedAt.
model User {
  id           String     @id @default(uuid()) @db.Uuid
  email        String     @unique
  username     String     @unique
  displayName  String
  passwordHash String
  status       UserStatus @default(PENDING_VERIFICATION)
  avatarUrl    String?
  timezone     String     @default("UTC")
  lastLoginAt  DateTime?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  deletedAt    DateTime?

  sessions      Session[]
  ownedProjects Project[]      @relation("ProjectOwner")
  investigations Investigation[]
  auditLogs     AuditLog[]
  userRoles     UserRole[]
  conversations      Conversation[]
  sessionMemories    SessionMemory[]
  contextWindows     ContextWindow[]
  promptAssemblies   PromptAssembly[]
  reasoningSessions  Reasoning[]
  executions         Execution[]
  streamingSessions  Streaming[]
  favorites          Favorite[]
  notifications      Notification[]
  preferences        UserPreference[]
  apiKeys            ApiKey[]
  activityLogs       ActivityLog[]
  comments           Comment[]

  @@index([email])
  @@index([username])
  @@index([status])
  @@index([createdAt])
  @@map("users")
}

// ─────────────────────────────────────────────────────────────────────────────
// USER-ROLE JUNCTION
// ─────────────────────────────────────────────────────────────────────────────

model UserRole {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @db.Uuid
  roleId    String   @db.Uuid
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Restrict)

  @@unique([userId, roleId])
  @@index([roleId])
  @@map("user_roles")
}

// ─────────────────────────────────────────────────────────────────────────────
// SESSION
// ─────────────────────────────────────────────────────────────────────────────

/// Authentication session produced on login.  Revoked on logout or expiry.
model Session {
  id           String        @id @default(uuid()) @db.Uuid
  userId       String        @db.Uuid
  tokenHash    String        @unique          // SHA-256 of the raw JWT/token
  status       SessionStatus @default(ACTIVE)
  ipAddress    String?
  userAgent    String?
  expiresAt    DateTime
  revokedAt    DateTime?
  lastActiveAt DateTime      @default(now())
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  deletedAt    DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@index([expiresAt])
  @@index([createdAt])
  @@map("sessions")
}

// ─────────────────────────────────────────────────────────────────────────────
// PROJECT
// ─────────────────────────────────────────────────────────────────────────────

/// Top-level workspace that groups investigations and captures.
model Project {
  id          String        @id @default(uuid()) @db.Uuid
  ownerId     String        @db.Uuid
  name        String
  description String?
  status      ProjectStatus @default(ACTIVE)
  tags        String[]      @default([])      // free-text labels
  metadata    Json?                           // arbitrary extension bag
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  deletedAt   DateTime?

  owner          User            @relation("ProjectOwner", fields: [ownerId], references: [id], onDelete: Restrict)
  investigations Investigation[]
  auditLogs      AuditLog[]
  assets             Asset[]
  evidence           Evidence[]
  timelineEvents     TimelineEvent[]
  findings           Finding[]
  alerts             Alert[]
  notes              Note[]
  reports            Report[]
  attackGraphNodes   AttackGraphNode[]
  attackGraphEdges   AttackGraphEdge[]
  conversations      Conversation[]
  sessionMemories    SessionMemory[]
  contextWindows     ContextWindow[]
  promptAssemblies   PromptAssembly[]
  reasoningSessions  Reasoning[]
  executions         Execution[]
  streamingSessions  Streaming[]
  playbooks          Playbook[]
  rules              Rule[]
  automations        Automation[]
  caseFlows          CaseFlow[]
  projectTags        Tag[]
  attachments        Attachment[]
  comments           Comment[]
  activityLogs       ActivityLog[]

  @@index([ownerId])
  @@index([status])
  @@index([createdAt])
  @@map("projects")
}

// ─────────────────────────────────────────────────────────────────────────────
// INVESTIGATION
// ─────────────────────────────────────────────────────────────────────────────

/// Structured analysis task within a project.
model Investigation {
  id          String              @id @default(uuid()) @db.Uuid
  projectId   String              @db.Uuid
  ownerId     String              @db.Uuid
  title       String
  description String?
  status      InvestigationStatus @default(OPEN)
  priority    Int                 @default(2)   // 1=critical 2=high 3=medium 4=low
  tags        String[]            @default([])
  metadata    Json?
  startedAt   DateTime?
  resolvedAt  DateTime?
  closedAt    DateTime?
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  deletedAt   DateTime?

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  owner   User    @relation(fields: [ownerId],   references: [id], onDelete: Restrict)
  assets             Asset[]
  evidence           Evidence[]
  timelineEvents     TimelineEvent[]
  findings           Finding[]
  alerts             Alert[]
  notes              Note[]
  reports            Report[]
  attackGraphNodes   AttackGraphNode[]
  attackGraphEdges   AttackGraphEdge[]
  conversations      Conversation[]
  sessionMemories    SessionMemory[]
  contextWindows     ContextWindow[]
  promptAssemblies   PromptAssembly[]
  reasoningSessions  Reasoning[]
  executions         Execution[]
  streamingSessions  Streaming[]
  playbooks          Playbook[]
  rules              Rule[]
  automations        Automation[]
  caseFlows          CaseFlow[]
  attachments        Attachment[]
  comments           Comment[]
  activityLogs       ActivityLog[]
  tagAssignments     TagAssignment[]

  @@index([projectId])
  @@index([ownerId])
  @@index([status])
  @@index([createdAt])
  @@index([projectId, status])
  @@map("investigations")
}

// ─────────────────────────────────────────────────────────────────────────────
// AUDIT LOG
// ─────────────────────────────────────────────────────────────────────────────

/// Immutable append-only audit trail for every user-initiated action.
model AuditLog {
  id           String      @id @default(uuid()) @db.Uuid
  userId       String      @db.Uuid
  projectId    String?     @db.Uuid            // nullable — some actions are global
  action       AuditAction
  resourceType String                          // "user" | "project" | "investigation" | …
  resourceId   String?                         // PK of the affected resource
  description  String?                         // human-readable summary
  ipAddress    String?
  userAgent    String?
  metadata     Json?                           // diff / payload snapshot
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  deletedAt    DateTime?

  user    User     @relation(fields: [userId],    references: [id], onDelete: Restrict)
  project Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([projectId])
  @@index([action])
  @@index([resourceType])
  @@index([createdAt])
  @@index([userId, createdAt])
  @@map("audit_logs")
}

// ─────────────────────────────────────────────────────────────────────────────
// INVESTIGATION MODELS (Phase A5.1.3)
// ─────────────────────────────────────────────────────────────────────────────

enum AssetType {
  SERVER
  WORKSTATION
  ROUTER
  SWITCH
  FIREWALL
  MOBILE
  IOT
  CLOUD
  UNKNOWN
  OTHER
}

enum FindingSeverity {
  INFO
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum FindingStatus {
  OPEN
  CONFIRMED
  SUPPRESSED
  FALSE_POSITIVE
  RESOLVED
  CLOSED
}

enum AlertSeverity {
  INFO
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum AlertStatus {
  NEW
  OPEN
  ACKNOWLEDGED
  IN_PROGRESS
  RESOLVED
  CLOSED
  SUPPRESSED
}

enum TimelineEventType {
  OBSERVED
  IDENTITY_MATCH
  IDENTITY_CREATED
  RELATIONSHIP_CREATED
  RELATIONSHIP_UPDATED
  EVIDENCE_ADDED
  HISTORY_CREATED
  ALERT_GENERATED
  FINDING_CREATED
  MITRE_MAPPED
  ATTACK_PATTERN
  ATTACK_CHAIN
  BLAST_RADIUS
  LATERAL_MOVEMENT
  PIVOT
  CHOKE_POINT
  MANUAL_ACTION
}

enum EvidenceType {
  PACKET
  LOG
  FILE
  REGISTRY
  PROCESS
  IOC
  ARTIFACT
  METRIC
  USER_INPUT
  OTHER
}

enum ReportStatus {
  DRAFT
  READY
  PUBLISHED
  ARCHIVED
}

model Asset {
  id              String          @id @default(uuid()) @db.Uuid
  projectId       String          @db.Uuid
  investigationId String          @db.Uuid
  macAddress      String?
  hostname        String?
  deviceName      String?
  vendor          String?
  operatingSystem String?
  currentIp       String?
  currentStatus   String?
  type            AssetType       @default(UNKNOWN)
  riskScore       Float           @default(0.0)
  confidence      Float           @default(100.0)
  
  // Common fields
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  deletedAt       DateTime?
  createdBy       String
  updatedBy       String
  version         Int             @default(1)
  metadata        Json?

  // Relations
  project        Project       @relation(fields: [projectId], references: [id], onDelete: NoAction)
  investigation  Investigation @relation(fields: [investigationId], references: [id], onDelete: Cascade)
  evidence       Evidence[]
  findings       Finding[]

  @@index([investigationId])
  @@index([projectId])
  @@index([createdAt])
  @@index([updatedAt])
  @@map("assets")
}

model Evidence {
  id              String          @id @default(uuid()) @db.Uuid
  projectId       String          @db.Uuid
  investigationId String          @db.Uuid
  assetId         String?         @db.Uuid
  findingId       String?         @db.Uuid
  fieldName       String
  fieldValue      String
  sourceType      String
  type            EvidenceType    @default(OTHER)
  rawValue        String?
  observedAt      DateTime        @default(now())
  confidence      Int             @default(100)

  // Common fields
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  deletedAt       DateTime?
  createdBy       String
  updatedBy       String
  version         Int             @default(1)
  metadata        Json?

  // Relations
  project        Project       @relation(fields: [projectId], references: [id], onDelete: NoAction)
  investigation  Investigation @relation(fields: [investigationId], references: [id], onDelete: Cascade)
  asset          Asset?        @relation(fields: [assetId], references: [id], onDelete: SetNull)
  finding        Finding?      @relation(fields: [findingId], references: [id], onDelete: SetNull)

  @@index([investigationId])
  @@index([projectId])
  @@index([assetId])
  @@index([findingId])
  @@index([createdAt])
  @@index([updatedAt])
  @@map("evidence")
}

model TimelineEvent {
  id              String            @id @default(uuid()) @db.Uuid
  projectId       String            @db.Uuid
  investigationId String            @db.Uuid
  title           String
  description     String?
  type            TimelineEventType @default(OBSERVED)
  eventTimestamp  DateTime          @default(now())

  // Common fields
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  deletedAt       DateTime?
  createdBy       String
  updatedBy       String
  version         Int             @default(1)
  metadata        Json?

  // Relations
  project        Project       @relation(fields: [projectId], references: [id], onDelete: NoAction)
  investigation  Investigation @relation(fields: [investigationId], references: [id], onDelete: Cascade)

  @@index([investigationId])
  @@index([projectId])
  @@index([createdAt])
  @@index([updatedAt])
  @@map("timeline_events")
}

model Finding {
  id              String          @id @default(uuid()) @db.Uuid
  projectId       String          @db.Uuid
  investigationId String          @db.Uuid
  assetId         String?         @db.Uuid
  title           String
  description     String?
  category        String          @default("OTHER")
  severity        FindingSeverity @default(MEDIUM)
  status          FindingStatus   @default(OPEN)
  riskScore       Float           @default(0.0)
  confidence      Float           @default(100.0)

  // Common fields
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  deletedAt       DateTime?
  createdBy       String
  updatedBy       String
  version         Int             @default(1)
  metadata        Json?

  // Relations
  project        Project       @relation(fields: [projectId], references: [id], onDelete: NoAction)
  investigation  Investigation @relation(fields: [investigationId], references: [id], onDelete: Cascade)
  asset          Asset?        @relation(fields: [assetId], references: [id], onDelete: SetNull)
  evidence       Evidence[]
  alerts         Alert[]

  @@index([investigationId])
  @@index([projectId])
  @@index([assetId])
  @@index([severity])
  @@index([status])
  @@index([createdAt])
  @@index([updatedAt])
  @@map("findings")
}

model Alert {
  id              String        @id @default(uuid()) @db.Uuid
  projectId       String        @db.Uuid
  investigationId String        @db.Uuid
  findingId       String?       @db.Uuid
  title           String
  description     String?
  severity        AlertSeverity @default(MEDIUM)
  status          AlertStatus   @default(NEW)
  source          String        @default("FINDING")
  riskScore       Float         @default(0.0)
  confidence      Float         @default(100.0)

  // Common fields
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  deletedAt       DateTime?
  createdBy       String
  updatedBy       String
  version         Int             @default(1)
  metadata        Json?

  // Relations
  project        Project       @relation(fields: [projectId], references: [id], onDelete: NoAction)
  investigation  Investigation @relation(fields: [investigationId], references: [id], onDelete: Cascade)
  finding        Finding?      @relation(fields: [findingId], references: [id], onDelete: SetNull)

  @@index([investigationId])
  @@index([projectId])
  @@index([findingId])
  @@index([severity])
  @@index([status])
  @@index([createdAt])
  @@index([updatedAt])
  @@map("alerts")
}

model AttackGraphNode {
  id              String   @id @default(uuid()) @db.Uuid
  projectId       String   @db.Uuid
  investigationId String   @db.Uuid
  label           String
  type            String   @default("host")
  x               Float?
  y               Float?

  // Common fields
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  deletedAt       DateTime?
  createdBy       String
  updatedBy       String
  version         Int             @default(1)
  metadata        Json?

  // Relations
  project        Project           @relation(fields: [projectId], references: [id], onDelete: NoAction)
  investigation  Investigation     @relation(fields: [investigationId], references: [id], onDelete: Cascade)
  outgoingEdges  AttackGraphEdge[] @relation("EdgeSource")
  incomingEdges  AttackGraphEdge[] @relation("EdgeTarget")

  @@index([investigationId])
  @@index([projectId])
  @@index([createdAt])
  @@index([updatedAt])
  @@map("attack_graph_nodes")
}

model AttackGraphEdge {
  id              String   @id @default(uuid()) @db.Uuid
  projectId       String   @db.Uuid
  investigationId String   @db.Uuid
  sourceNodeId    String   @db.Uuid
  targetNodeId    String   @db.Uuid
  label           String?
  weight          Float    @default(1.0)

  // Common fields
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  deletedAt       DateTime?
  createdBy       String
  updatedBy       String
  version         Int             @default(1)
  metadata        Json?

  // Relations
  project        Project         @relation(fields: [projectId], references: [id], onDelete: NoAction)
  investigation  Investigation   @relation(fields: [investigationId], references: [id], onDelete: Cascade)
  sourceNode     AttackGraphNode @relation("EdgeSource", fields: [sourceNodeId], references: [id], onDelete: Cascade)
  targetNode     AttackGraphNode @relation("EdgeTarget", fields: [targetNodeId], references: [id], onDelete: Cascade)

  @@index([investigationId])
  @@index([projectId])
  @@index([sourceNodeId])
  @@index([targetNodeId])
  @@index([createdAt])
  @@index([updatedAt])
  @@map("attack_graph_edges")
}

model Note {
  id              String   @id @default(uuid()) @db.Uuid
  projectId       String   @db.Uuid
  investigationId String   @db.Uuid
  title           String?
  content         String

  // Common fields
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  deletedAt       DateTime?
  createdBy       String
  updatedBy       String
  version         Int             @default(1)
  metadata        Json?

  // Relations
  project        Project       @relation(fields: [projectId], references: [id], onDelete: NoAction)
  investigation  Investigation @relation(fields: [investigationId], references: [id], onDelete: Cascade)

  @@index([investigationId])
  @@index([projectId])
  @@index([createdAt])
  @@index([updatedAt])
  @@map("notes")
}

model Report {
  id              String       @id @default(uuid()) @db.Uuid
  projectId       String       @db.Uuid
  investigationId String       @db.Uuid
  title           String
  content         String
  type            String       @default("SUMMARY")
  status          ReportStatus @default(DRAFT)

  // Common fields
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  deletedAt       DateTime?
  createdBy       String
  updatedBy       String
  version         Int             @default(1)
  metadata        Json?

  // Relations
  project        Project       @relation(fields: [projectId], references: [id], onDelete: NoAction)
  investigation  Investigation @relation(fields: [investigationId], references: [id], onDelete: Cascade)

  @@index([investigationId])
  @@index([projectId])
  @@index([status])
  @@index([createdAt])
  @@index([updatedAt])
  @@map("reports")
}

// ─────────────────────────────────────────────────────────────────────────────
// AI MODELS (Phase A5.1.4)
// ─────────────────────────────────────────────────────────────────────────────

enum ConversationStatus {
  ACTIVE
  ARCHIVED
  COMPLETED
  DELETED
}

enum ExecutionStatus {
  ACTIVE
  COMPLETED
  FAILED
  PENDING
}

enum ProviderStatus {
  ACTIVE
  INACTIVE
  DEGRADED
}

enum StreamingStatus {
  ACTIVE
  COMPLETED
  FAILED
  PENDING
}

enum ReasoningStatus {
  ACTIVE
  COMPLETED
  FAILED
  PENDING
}

enum PromptStatus {
  ACTIVE
  ARCHIVED
  DRAFT
}

enum MemoryStatus {
  ACTIVE
  INACTIVE
  ARCHIVED
}

enum ContextStatus {
  ACTIVE
  INACTIVE
  ARCHIVED
}

enum ProviderType {
  CLOUD
  LOCAL
  HYBRID
}

model Conversation {
  id              String             @id @default(uuid()) @db.Uuid
  projectId       String             @db.Uuid
  investigationId String?            @db.Uuid
  userId          String?            @db.Uuid
  title           String
  status          ConversationStatus @default(ACTIVE)
  summary         String?
  tags            String[]           @default([])
  contextSize     Int                @default(0)

  // Common fields
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  deletedAt       DateTime?
  createdBy       String
  updatedBy       String
  version         Int             @default(1)
  metadata        Json?

  // Relations
  project        Project         @relation(fields: [projectId], references: [id], onDelete: NoAction)
  investigation  Investigation?  @relation(fields: [investigationId], references: [id], onDelete: Cascade)
  user           User?           @relation(fields: [userId], references: [id], onDelete: SetNull)
  messages       ConversationMessage[]
  sessionMemories SessionMemory[]
  contextWindows  ContextWindow[]

  @@index([userId])
  @@index([projectId])
  @@index([investigationId])
  @@index([status])
  @@index([createdAt])
  @@index([updatedAt])
  @@map("conversations")
}

model ConversationMessage {
  id              String             @id @default(uuid()) @db.Uuid
  conversationId  String             @db.Uuid
  parentMessageId String?            @db.Uuid
  role            String
  content         String

  // Common fields
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  deletedAt       DateTime?
  createdBy       String
  updatedBy       String
  version         Int             @default(1)
  metadata        Json?

  // Relations
  conversation    Conversation       @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  parentMessage   ConversationMessage? @relation("MessageThread", fields: [parentMessageId], references: [id], onDelete: SetNull)
  replies         ConversationMessage[] @relation("MessageThread")

  @@index([conversationId])
  @@index([createdAt])
  @@index([updatedAt])
  @@map("conversation_messages")
}

model SessionMemory {
  id              String             @id @default(uuid()) @db.Uuid
  conversationId  String             @db.Uuid
  investigationId String?            @db.Uuid
  projectId       String             @db.Uuid
  userId          String?            @db.Uuid
  status          MemoryStatus       @default(ACTIVE)
  contextSize     Int                @default(0)
  sessionName     String?

  // Common fields
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  deletedAt       DateTime?
  createdBy       String
  updatedBy       String
  version         Int             @default(1)
  metadata        Json?

  // Relations
  conversation    Conversation    @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  investigation   Investigation?  @relation(fields: [investigationId], references: [id], onDelete: Cascade)
