  threatActor   ThreatActor?    @relation(fields: [threatId], references: [id], onDelete: Cascade)
  threatCampaign ThreatCampaign? @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@index([iocId])
  @@index([cveId])
