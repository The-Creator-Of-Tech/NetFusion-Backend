  description       String?
  severity          CVESeverity
  cvssScore         Float
  publishedDate     DateTime?
  modifiedDate      DateTime?
  references        String[]        @default([])
  affectedPlatforms String[]        @default([])
  exploited         Boolean         @default(false)
  patched           Boolean         @default(false)
  vendor            String?
  product           String?

  // Common fields
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  deletedAt   DateTime?
  createdBy   String
  updatedBy   String
  version     Int             @default(1)
  metadata    Json?

  // Relations
  cvss              CVSS?
  affectedProducts  AffectedProduct[]
  techniques        MitreTechnique[] @relation("CVETechniques")
  iocs              IOC[]            @relation("CVEIOCs")
  threatRelationships ThreatRelationship[]
  iocRelationships  IOCRelationship[]

  @@index([severity])
  @@index([createdAt])
  @@index([updatedAt])
  @@map("cves")
}

