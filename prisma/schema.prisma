// ─────────────────────────────────────────────────────────────────────────────
// KNOWLEDGE MODELS (Phase A5.1.5)
// ─────────────────────────────────────────────────────────────────────────────

enum MitreTacticType {
  RECONNAISSANCE
  RESOURCE_DEVELOPMENT
  INITIAL_ACCESS
  EXECUTION
  PERSISTENCE
  PRIVILEGE_ESCALATION
  DEFENSE_EVASION
  CREDENTIAL_ACCESS
  DISCOVERY
  LATERAL_MOVEMENT
  COLLECTION
  COMMAND_AND_CONTROL
  EXFILTRATION
  IMPACT
}

enum CVESeverity {
  NONE
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum IOCType {
  IP
  DOMAIN
  URL
  HASH_MD5
  HASH_SHA1
  HASH_SHA256
  EMAIL
  FILE_PATH
  MUTEX
  REGISTRY_KEY
}

enum IOCStatus {
  ACTIVE
  INACTIVE
  FALSE_POSITIVE
  SUSPICIOUS
  REVOKED
}

enum ThreatLevel {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum ThreatStatus {
  ACTIVE
  INACTIVE
  MONITORED
  UNKNOWN
}

enum CampaignStatus {
  ACTIVE
  INACTIVE
  COMPLETED
  PAUSED
}

enum RelationshipType {
  EXPLOITS
  USES
  ATTRIBUTED_TO
  ASSOCIATED_WITH
  TARGETS
}

model MitreTactic {
  id          String          @id @default(uuid()) @db.Uuid
  tacticKey   String          @unique
  name        String
  description String?
  tacticType  MitreTacticType

  // Common fields
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  deletedAt   DateTime?
  createdBy   String
  updatedBy   String
  version     Int             @default(1)
  metadata    Json?

  // Relations
  techniques  MitreTechnique[]

  @@index([createdAt])
  @@index([updatedAt])
  @@map("mitre_tactics")
}

model MitreTechnique {
  id          String          @id @default(uuid()) @db.Uuid
  tacticId    String?         @db.Uuid
  mitreId     String          @unique
  name        String
  description String?
  detection   String?
  platforms   String[]        @default([])
  references  String[]        @default([])
  severity    CVESeverity     @default(MEDIUM)
  dataSource  String?
  revoked     Boolean         @default(false)
  deprecated  Boolean         @default(false)

  // Common fields
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  deletedAt   DateTime?
  createdBy   String
  updatedBy   String
  version     Int             @default(1)
  metadata    Json?

  // Relations
  tactic      MitreTactic?    @relation(fields: [tacticId], references: [id], onDelete: SetNull)
  mitigations MitreMitigation[] @relation("TechniqueMitigations")
  cves        CVE[]           @relation("CVETechniques")
  iocs        IOC[]           @relation("IOCTechniques")
  threatActors ThreatActor[]   @relation("ActorTechniques")
  threatCampaigns ThreatCampaign[] @relation("CampaignTechniques")
  threatRelationships ThreatRelationship[]
  iocRelationships IOCRelationship[]

  @@index([severity])
  @@index([createdAt])
  @@index([updatedAt])
  @@map("mitre_techniques")
}

model MitreMitigation {
  id          String          @id @default(uuid()) @db.Uuid
  mitreId     String          @unique
  name        String
  description String?

  // Common fields
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  deletedAt   DateTime?
  createdBy   String
  updatedBy   String
  version     Int             @default(1)
  metadata    Json?

  // Relations
