generator client {
  provider = "prisma-client-js"
  output   = "./src/generated/sqlite-client"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

// ─────────────────────────────────────────────────────────────────────────────
// EXISTING MODELS — untouched
// ─────────────────────────────────────────────────────────────────────────────

model ScanRun {
  id               String          @id @default(uuid())
  projectId        String
  captureId        String?
  startedAt        DateTime        @default(now())
  completedAt      DateTime?
  status           String          @default("pending")
  packetCount      Int             @default(0)
  summary          String?
  findings         String?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  captureSession   CaptureSession? @relation(fields: [captureSessionId], references: [id])
  captureSessionId String?
}

model CaptureSession {
  id                String    @id @default(uuid())
  projectId         String
  captureId         String?
  packetCount       Int       @default(0)
  analysis          String?
  timeline          String?
  alerts            String?
  iocs              String?
  correlations      String?
  mitre             String?
  riskRanking       String?
  attackStory       String?
  investigationPlan String?
  executiveReport   String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  scanRuns          ScanRun[]
}

model ReportArchive {
  id         String   @id @default(uuid())
  projectId  String
  reportType String
  reportData String
  createdAt  DateTime @default(now())
  archivedAt DateTime @default(now())
}

model PcapInvestigation {
  id                  String   @id @default(uuid())
  projectId           String
  filename            String
  summary             String?
  findings            String?
  alerts              String?
  iocs                String?
  correlations        String?
  timeline            String?
  mitre               String?
  riskRanking         String?
  trafficIntelligence String?
  attackStory         String?
  investigationPlan   String?
  executiveReport     String?
  createdAt           DateTime @default(now())
}

model NmapScan {
  id         String   @id @default(uuid())
  projectId  String
  target     String
  profile    String   @default("quick")
  resultJson String?
  rawOutput  String?
  createdAt  DateTime @default(now())
}

// ─────────────────────────────────────────────────────────────────────────────
// ENTERPRISE ASSET MODELS
// ─────────────────────────────────────────────────────────────────────────────

/// Root identity record for a discovered network asset.
/// All searchable attributes are stored in normalized child tables.
/// Only `notes` and `metadata` remain as free-form string/JSON fields.
model Asset {
  id         String   @id @default(uuid())
  projectId  String
  deviceType String? // "router" | "workstation" | "mobile" | "server" | "iot" | …
  vendor     String?
  os         String?
  osVersion  String?
  firstSeen  DateTime @default(now())
  lastSeen   DateTime @default(now())
  confidence Float    @default(0.0) // 0.0–1.0 identity confidence score
  riskScore  Float    @default(0.0) // 0.0–100.0 composite risk score
  isManaged  Boolean  @default(false)
  notes      String? // free-text analyst notes — intentionally kept as string
  metadata   String? // arbitrary JSON extension bag — intentionally kept as string
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  // ── Normalized relations ──────────────────────────────────────────────────
  hostnames     AssetHostname[]
  ipAddresses   AssetIPAddress[]
  macAddresses  AssetMAC[]
  ssids         AssetSSID[]
  ports         AssetPort[]
  services      AssetService[]
  tags          AssetTag[]
  evidence      AssetFieldEvidence[]
  relationsFrom AssetRelationship[]  @relation("RelationshipSource")
  relationsTo   AssetRelationship[]  @relation("RelationshipTarget")

  @@index([projectId])
  @@index([riskScore])
  @@index([lastSeen])
  @@index([projectId, lastSeen])
  @@index([projectId, riskScore])
}

// ─────────────────────────────────────────────────────────────────────────────

/// Every hostname ever observed for an asset (DNS, mDNS, NetBIOS, LLMNR, …).
model AssetHostname {
  id         String   @id @default(uuid())
  assetId    String
  asset      Asset    @relation(fields: [assetId], references: [id], onDelete: Cascade)
  hostname   String
  isPrimary  Boolean  @default(false)
  confidence Float    @default(1.0)
  firstSeen  DateTime @default(now())
  lastSeen   DateTime @default(now())
  source     String? // "dns" | "mdns" | "netbios" | "llmnr" | "ptr" | "manual"

  @@unique([assetId, hostname])
  @@index([assetId])
  @@index([hostname])
}

// ─────────────────────────────────────────────────────────────────────────────

/// Full IP address history for an asset, including rotated/historical addresses.
model AssetIPAddress {
  id        String   @id @default(uuid())
  assetId   String
  asset     Asset    @relation(fields: [assetId], references: [id], onDelete: Cascade)
  ipAddress String
  isCurrent Boolean  @default(true)
  firstSeen DateTime @default(now())
  lastSeen  DateTime @default(now())
  source    String? // "capture" | "arp" | "dhcp" | "nmap" | "manual"

  @@unique([assetId, ipAddress])
  @@index([assetId])
  @@index([ipAddress])
  @@index([isCurrent])
}

// ─────────────────────────────────────────────────────────────────────────────

/// MAC address records — supports multi-interface and MAC rotation tracking.
model AssetMAC {
  id         String   @id @default(uuid())
  assetId    String
  asset      Asset    @relation(fields: [assetId], references: [id], onDelete: Cascade)
  macAddress String
  isCurrent  Boolean  @default(true)
  isPrimary  Boolean  @default(false)
  vendor     String? // OUI-resolved vendor, if known
  firstSeen  DateTime @default(now())
  lastSeen   DateTime @default(now())
  source     String? // "arp" | "capture" | "dhcp" | "manual"

  @@unique([assetId, macAddress])
  @@index([assetId])
  @@index([macAddress])
  @@index([isCurrent])
}

// ─────────────────────────────────────────────────────────────────────────────

/// WiFi SSIDs associated with an asset (probed, beacon, or association frames).
model AssetSSID {
  id        String   @id @default(uuid())
  assetId   String
  asset     Asset    @relation(fields: [assetId], references: [id], onDelete: Cascade)
  ssid      String
  isCurrent Boolean  @default(true)
  firstSeen DateTime @default(now())
  lastSeen  DateTime @default(now())
  source    String? // "probe" | "beacon" | "association" | "manual"

  @@unique([assetId, ssid])
  @@index([assetId])
  @@index([ssid])
}

// ─────────────────────────────────────────────────────────────────────────────

/// Open/filtered/closed ports observed on an asset via capture or active scan.
model AssetPort {
  id        String   @id @default(uuid())
  assetId   String
  asset     Asset    @relation(fields: [assetId], references: [id], onDelete: Cascade)
  port      Int
  protocol  String   @default("tcp") // "tcp" | "udp" | "sctp"
  service   String? // banner-level hint, e.g. "http"
  state     String   @default("open") // "open" | "closed" | "filtered"
  firstSeen DateTime @default(now())
  lastSeen  DateTime @default(now())

  @@unique([assetId, port, protocol])
  @@index([assetId])
  @@index([port])
  @@index([protocol])
  @@index([state])
}

// ─────────────────────────────────────────────────────────────────────────────

/// Identified application-layer services running on an asset.
model AssetService {
  id         String  @id @default(uuid())
  assetId    String
  asset      Asset   @relation(fields: [assetId], references: [id], onDelete: Cascade)
  name       String // "http" | "ssh" | "smb" | "rdp" | …
  version    String?
  protocol   String?
  port       Int?
  confidence Float   @default(1.0)

  @@index([assetId])
  @@index([name])
  @@index([port])
}

// ─────────────────────────────────────────────────────────────────────────────

/// Analyst-applied or auto-generated classification labels for an asset.
model AssetTag {
  id        String   @id @default(uuid())
  assetId   String
  asset     Asset    @relation(fields: [assetId], references: [id], onDelete: Cascade)
  tag       String
  createdAt DateTime @default(now())

  @@unique([assetId, tag])
  @@index([assetId])
  @@index([tag])
}

// ─────────────────────────────────────────────────────────────────────────────

/// Generic evidence trail linking any observed field value back to its source
/// (pcap packet, Nmap scan result, DNS response, manual entry, etc.).
/// Acts as an audit log and supports confidence scoring per observation.
model AssetFieldEvidence {
  id           String   @id @default(uuid())
  assetId      String
  asset        Asset    @relation(fields: [assetId], references: [id], onDelete: Cascade)
  fieldName    String // "hostname" | "ipAddress" | "os" | "vendor" | …
  fieldValue   String // the observed value
  confidence   Float    @default(1.0)
  sourceType   String? // "pcap" | "nmap" | "dns" | "arp" | "manual"
  sourceId     String? // loose ref to CaptureSession.id / NmapScan.id
  packetNumber Int? // packet index within the capture file
  captureId    String? // ties back to CaptureSession.captureId
  observedAt   DateTime @default(now())
  metadata     String? // arbitrary JSON for extended context

  @@index([assetId])
  @@index([assetId, fieldName])
  @@index([fieldName])
  @@index([captureId])
  @@index([sourceType, sourceId])
  @@index([observedAt])
}

// ─────────────────────────────────────────────────────────────────────────────

/// Directed graph of relationships between assets.
/// Examples: "communicates_with", "resolves_to", "routes_through", "hosts"
model AssetRelationship {
  id               String   @id @default(uuid())
  sourceId         String
  targetId         String
  source           Asset    @relation("RelationshipSource", fields: [sourceId], references: [id], onDelete: Cascade)
  target           Asset    @relation("RelationshipTarget", fields: [targetId], references: [id], onDelete: Cascade)
  relationshipType String // "communicates_with" | "resolves_to" | "routes_through" | "hosts" | …
  confidence       Float    @default(1.0)
  firstSeen        DateTime @default(now())
  lastSeen         DateTime @default(now())
  metadata         String? // arbitrary JSON

  @@unique([sourceId, targetId, relationshipType])
  @@index([sourceId])
  @@index([targetId])
  @@index([relationshipType])
}

// ─────────────────────────────────────────────────────────────────────────────
// ENTERPRISE RELATIONSHIP MODELS — Phase A.3.1
// ─────────────────────────────────────────────────────────────────────────────

/// Full relationship record produced by the Relationship Engine.
/// Scoped to a project.  Natural key:
///   (projectId, sourceAssetId, targetAssetId, relationshipType, protocol, port)
/// UPSERT on that key — never duplicate a relationship, just update it.
model Relationship {
  id        String @id @default(uuid())
  projectId String

  // ── Asset endpoints ───────────────────────────────────────────────────────
  sourceAssetId String // Asset.id — originating asset
  targetAssetId String // Asset.id — receiving asset

  // ── Relationship classification ───────────────────────────────────────────
  relationshipType String // RelationshipType enum value
  protocol         String // normalised uppercase protocol, e.g. "DNS"
  port             Int? // destination port; NULL for ICMP/ARP/DHCP

  // ── Direction & lifecycle ─────────────────────────────────────────────────
  direction String @default("UNKNOWN") // Direction enum value
  state     String @default("NEW") // RelationshipState enum value

  // ── Natural-key hash — single-column fast lookup ──────────────────────────
  // SHA-256[:32] over (projectId|sourceAssetId|targetAssetId|type|protocol|port)
  // Generated once by relationship_service.compute_relationship_key().
  // Indexed for O(1) lookup by key from AI, Redis, Neo4j, and API routes.
  relationshipKey String? @unique

  // ── Traffic metrics ───────────────────────────────────────────────────────
  packetCount Int @default(0)
  byteCount   Int @default(0)

  // ── Temporal bounds ───────────────────────────────────────────────────────
  firstSeen DateTime @default(now())
  lastSeen  DateTime @default(now())

  // ── Confidence & evidence pointers ───────────────────────────────────────
  confidence     Float   @default(0.0) // 0–100
  lastEvidenceId String? // evidenceId of most-recent linked EvidenceRecord

  // ── Engine provenance ─────────────────────────────────────────────────────
  engineVersion String?
  metadata      String? // arbitrary JSON

  // ── Timestamps ────────────────────────────────────────────────────────────
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // ── Child evidence links ──────────────────────────────────────────────────
  evidenceLinks RelationshipEvidence[]

  // ── Natural-key uniqueness — drives UPSERT deduplication ─────────────────
  @@unique([projectId, sourceAssetId, targetAssetId, relationshipType, protocol, port])
  @@index([projectId])
  @@index([sourceAssetId])
  @@index([targetAssetId])
  @@index([projectId, sourceAssetId])
  @@index([projectId, targetAssetId])
  @@index([relationshipType])
  @@index([state])
  @@index([lastSeen])
  @@index([projectId, lastSeen])
}

// ─────────────────────────────────────────────────────────────────────────────

/// Append-only evidence trail for one Relationship.
/// Each row links one EvidenceRecord (by its stable evidenceId) to the
/// Relationship it supports.  Deduplication key: (relationshipId, evidenceId).
model RelationshipEvidence {
  id             String       @id @default(uuid())
  relationshipId String
  relationship   Relationship @relation(fields: [relationshipId], references: [id], onDelete: Cascade)

  evidenceId   String // EvidenceRecord.evidenceId (stable UUID v5)
  captureId    String? // CaptureSession.captureId — for fast capture scoping
  packetNumber Int? // frame index within capture file
  sourceType   String? // "pcap" | "dhcp" | "arp" | …
  observedAt   DateTime @default(now())
  metadata     String? // arbitrary JSON

  createdAt DateTime @default(now())

  // ── Deduplication key ─────────────────────────────────────────────────────
  @@unique([relationshipId, evidenceId])
  @@index([relationshipId])
  @@index([evidenceId])
  @@index([captureId])
  @@index([observedAt])
}

// ─────────────────────────────────────────────────────────────────────────────

/// Immutable append-only audit log for every state change a Relationship
/// passes through.  One row per atomic mutation.
///
/// Key AI-facing fields
/// --------------------
/// changedFields  — JSON array of field names that changed in this event.
///                  e.g. '["confidence","packetCount","byteCount"]'
///                  AI Copilot reads this to generate targeted explanations
///                  without needing to diff rows itself.
///
/// changeReason   — stable human-readable reason string from
///                  RELATIONSHIP_CHANGE_REASON_* constants.
///                  e.g. "New packet observed" | "New evidence linked"
///                  AI Copilot uses this as the primary explanation label.
///                  GROUP BY changeReason enables trend analytics.
model RelationshipHistory {
  id String @id @default(uuid())

  // ── Parent relationship identity ──────────────────────────────────────────
  relationshipId   String // Relationship.id (PK) — loose FK for speed
  relationshipKey  String // SHA-256[:32] — AI/Redis short reference
  projectId        String
  sourceAssetId    String // copied for fast asset-scoped queries
  targetAssetId    String // copied for fast asset-scoped queries
  relationshipType String
  protocol         String
  port             Int?

  // ── Event classification ──────────────────────────────────────────────────
  eventType String // RelationshipEventType enum value

  // ── MANDATORY AI FIELDS ───────────────────────────────────────────────────
  changedFields String // JSON array: ["confidence","state",…]
  changeReason  String // stable reason string for AI Copilot

  // ── Before / after snapshots ──────────────────────────────────────────────
  // Stored as JSON strings so no schema migration is needed when snapshot
  // fields evolve.  NULL previousSnapshot = CREATED (first observation).
  previousSnapshot String? // JSON: RelationshipSnapshot | null
  currentSnapshot  String // JSON: RelationshipSnapshot

  // ── Event ordering ────────────────────────────────────────────────────────
  sequenceNumber Int     @default(0) // monotonic within a relationshipId
  parentEventId  String? // eventId of preceding event (chain)

  // ── Timestamps & provenance ───────────────────────────────────────────────
  occurredAt    DateTime @default(now())
  summary       String? // deterministic one-line description
  engineVersion String?
  metadata      String? // arbitrary JSON

  createdAt DateTime @default(now())

  // ── Deduplication: one event per (relationshipId, eventType, occurredAt) ──
  @@unique([relationshipId, eventType, occurredAt])
  @@index([relationshipId])
  @@index([relationshipKey])
  @@index([projectId])
  @@index([sourceAssetId])
  @@index([targetAssetId])
  @@index([eventType])
  @@index([changeReason])
  @@index([occurredAt])
  @@index([projectId, occurredAt])
  @@index([relationshipId, occurredAt])
}
