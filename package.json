{
  "name": "netfusion-prisma",
  "version": "0.1.0",
  "private": true,
  "type": "commonjs",
  "dependencies": {
    "express": "^4.18.2",
    "@prisma/client": "^5.22.0",
    "body-parser": "^1.20.2"
  },
  "devDependencies": {
    "prisma": "^5.20.0",
    "typescript": "^5.2.2",
    "@types/express": "^4.17.21",
    "ts-node": "^10.9.1"
  },
  "scripts": {
    "prisma": "prisma",
    "migrate": "prisma migrate dev --name add_capture_models",
    "generate": "prisma generate",
