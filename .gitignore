```gitignore
# Environment variables
.env
.env.*

# Virtual environments
venv/
.venv/
env/

# Python cache
__pycache__/
*.py[cod]
*.pyo
*.pyd

# Node.js 
node_modules/

# Local database
dev.db
dev.db-journal

# Generated session files
session_*.json

# Reports
report.pdf

# Logs
*.log

# Test & coverage
.pytest_cache/
.coverage
htmlcov/

# IDE files
.vscode/
.idea/

# OS files
.DS_Store
Thumbs.db
```

